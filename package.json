{
  "name": "airouter",
  "version": "1.0.0",
  "description": "Local AI API gateway for managing multiple upstream providers",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "airouter": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "config.yaml"
  ],
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noCheck",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "tui": "tsx src/tui/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "npm run build"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "chalk": "^5.3.0",
    "hono": "^4.6.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.9"
  }
}
